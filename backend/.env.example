# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/gabriel
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/gabriel

# LLM - provider: deepseek | openai | claude
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-v4-pro

# DeepSeek
DEEPSEEK_API_KEY=sk-your-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# OpenAI / OpenAI-compatible (for chat)
OPENAI_API_KEY=sk-your-key
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-your-key
ANTHROPIC_MODEL=claude-sonnet-4-6

# Embedding (OpenAI-compatible)
EMBEDDING_API_KEY=sk-your-key
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=text-embedding-3-small
